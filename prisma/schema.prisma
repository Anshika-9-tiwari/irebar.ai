generator client {
  provider = "prisma-client-js" 
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  mobile    String
  company   String
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}